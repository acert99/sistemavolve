# =============================================================================
# .env — Variáveis de ambiente da stack Docker (raiz)
# Copie para .env e preencha os valores reais
# =============================================================================

# Banco de dados
POSTGRES_PASSWORD=senha_super_segura_aqui

# Redis
REDIS_PASSWORD=redis_senha_segura_aqui

# NextAuth
NEXTAUTH_SECRET=gere_com_openssl_rand_base64_32

# Evolution API
EVOLUTION_API_KEY=sua_chave_evolution_api_aqui
EVOLUTION_WEBHOOK_SECRET=gere_com_openssl_rand_hex_32

# Asaas
ASAAS_API_KEY='$aact_...'
ASAAS_WEBHOOK_TOKEN=token_para_validar_webhooks_asaas
ASAAS_API_URL=https://api.asaas.com/v3

# Autentique
AUTENTIQUE_API_KEY=seu_token_autentique_aqui
AUTENTIQUE_WEBHOOK_SECRET=secret_para_validar_webhooks_autentique
AUTENTIQUE_API_URL=https://api.autentique.com.br/v2/graphql

# ClickUp
CLICKUP_WEBHOOK_SECRET=secret_para_validar_webhooks_clickup
CLICKUP_API_TOKEN=pk_seu_token_clickup_aqui
CLICKUP_TEAM_ID=seu_team_id_clickup
CLICKUP_SPACE_ID=
CLICKUP_FOLDER_ID_VOLVE=
CLICKUP_FOLDER_ID_VOLVE_HEALTH=
CLICKUP_PUBLIC_VIEW_URL_VOLVE=
CLICKUP_PUBLIC_VIEW_URL_VOLVE_HEALTH=

# Cron
CRON_SECRET=gere_com_openssl_rand_hex_32

# Defaults opcionais do app
EVOLUTION_INSTANCE_NAME=volve
NEXT_PUBLIC_SITE_URL=https://volvemkt.com
