# =============================================================================
# Caddyfile — Plataforma Volve
# SSL automático via Let's Encrypt (ACME)
# Substitua os domínios conforme necessário
# =============================================================================

# Painel interno + Portal do cliente (Next.js App)
app.volvemkt.com {
  reverse_proxy volve_app:3001

  # Headers de segurança
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https:; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self';"
    -Server
  }

  # Logs de acesso
  log {
    output file /var/log/caddy/app.volvemkt.com.log {
      roll_size 10mb
      roll_keep 5
    }
    format json
  }

  encode gzip zstd
}

# Gateway WhatsApp (Evolution API)
evolution.volvemkt.com {
  reverse_proxy volve_evolution:8080

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    -Server
  }

  # Bloqueia acesso ao painel da Evolution em produção
  @block_manager path /manager/*
  respond @block_manager 403

  log {
    output file /var/log/caddy/evolution.volvemkt.com.log {
      roll_size 10mb
      roll_keep 5
    }
    format json
  }

  encode gzip
}

