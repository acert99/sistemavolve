# =============================================================================
# Plataforma Volve — App (Painel + Portal do Cliente)
# Copie para .env.local e preencha os valores reais
# =============================================================================

# ----- Banco de Dados (PostgreSQL via Prisma) -----
DATABASE_URL="postgresql://volve:SENHA_POSTGRES@localhost:5432/volve?schema=public"

# ----- NextAuth -----
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="seu_nextauth_secret_aqui"
NEXTAUTH_URL="https://app.volvemkt.com"

# ----- Asaas (Gateway de Pagamento) -----
# Sandbox: https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/v3
ASAAS_API_KEY="$aact_..."
ASAAS_WEBHOOK_TOKEN="token_para_validar_webhooks_asaas"
ASAAS_API_URL="https://api.asaas.com/v3"

# ----- Autentique (Assinatura Eletrônica) -----
# https://autentique.com.br/api
AUTENTIQUE_API_KEY="seu_token_autentique_aqui"
AUTENTIQUE_WEBHOOK_SECRET="secret_para_validar_webhooks_autentique"
AUTENTIQUE_API_URL="https://api.autentique.com.br/v2/graphql"

# ----- Evolution API (WhatsApp) -----
EVOLUTION_API_URL="https://evolution.volvemkt.com"
EVOLUTION_API_KEY="sua_chave_evolution_api_aqui"
EVOLUTION_INSTANCE_NAME="volve"

# ----- ClickUp (Gestão de Tarefas) -----
CLICKUP_WEBHOOK_SECRET="secret_para_validar_webhooks_clickup"
CLICKUP_API_TOKEN="pk_seu_token_clickup_aqui"
CLICKUP_TEAM_ID="seu_team_id_clickup"

# ----- Cron Jobs (segurança) -----
# Gere com: openssl rand -hex 32
CRON_SECRET="seu_cron_secret_aqui"

# ----- Redis -----
REDIS_URL="redis://:SENHA_REDIS@localhost:6379"

# ----- URLs públicas -----
NEXT_PUBLIC_VPS_API_URL="https://app.volvemkt.com"
NEXT_PUBLIC_SITE_URL="https://volvemkt.com"
